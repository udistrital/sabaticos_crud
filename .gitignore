# =========================
# Go build files
# =========================
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Binary generado (como el que tienes: sabaticos_crud)
sabaticos_crud
sabaticos_crud.exe

# Carpeta bin opcional
/bin/
/build/
/dist/

# =========================
# Go workspace
# =========================
go.work
go.work.sum
go.mod
go.sum

# =========================
# Archivos temporales
# =========================
*.tmp
*.temp
lastupdate.tmp

# =========================
# Logs
# =========================
*.log
logs/
*.out

# =========================
# Archivos de entorno (NO subir secretos)
# =========================
.env
*.env
!.example.env
!.env.example
prueba.env

# =========================
# IDEs
# =========================

# VSCode
.vscode/
.history/

# GoLand / IntelliJ
.idea/

# Vim
*.swp
*.swo

# =========================
# OS files
# =========================

# Linux
*~

# macOS
.DS_Store

# Windows
Thumbs.db

# =========================
# Swagger generated files (opcional)
# =========================
swagger/**
!swagger/swagger.json
!swagger/swagger.yml

# =========================
# Test binary
# =========================
*.coverprofile
coverage.out

# =========================
# Vendor (solo si usas Go modules, normalmente NO se ignora si se usa vendor)
# =========================
vendor/

# =========================
# Archivos de configuración sensibles
# =========================
conf/app.conf.local
conf/*.local.conf
